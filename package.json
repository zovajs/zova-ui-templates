{
  "name": "zova",
  "private": true,
  "description": "A vue3 framework with ioc",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "type": "module",
  "scripts": {
    "init": "pnpm install --no-frozen-lockfile && pnpm --dir './zova-cli' install --no-frozen-lockfile && npm run zova-dev-deps",
    "zova-dev-deps": "cd ./zova-dev && node ../zova-cli/cli/src/bin/zova.ts :tools:deps",
    "docs:fix": "textlint --fix ./zova-docs/**/*.md",
    "release-patch": "./scripts/release.sh patch",
    "release-minor": "./scripts/release.sh minor"
  },
  "dependencies": {},
  "devDependencies": {
    "@cabloy/lint": "^5.1.15",
    "@cabloy/process-helper": "^3.1.3",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "lerna": "^8.1.2",
    "minimist": "^1.2.8",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "textlint": "^15.5.4",
    "textlint-rule-en-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-space-between-half-and-full-width": "^2.4.2",
    "textlint-rule-period-in-list-item": "^1.0.1",
    "typedoc": "^0.25.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "overrides": {
      "zod": "npm:@cabloy/zod@4.3.6"
    }
  }
}

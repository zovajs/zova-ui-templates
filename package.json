{
  "name": "zova",
  "private": true,
  "description": "A vue3 framework with ioc",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "type": "module",
  "scripts": {
    "init": "pnpm install --no-frozen-lockfile && pnpm --dir './zova-ui-empty' run init && pnpm --dir './zova-ui-quasar' run init && pnpm --dir './zova-ui-vuetify' run init",
    "release-patch": "./scripts/release.sh patch",
    "release-minor": "./scripts/release.sh minor"
  },
  "dependencies": {},
  "devDependencies": {
    "@cabloy/lint": "^5.1.15",
    "lerna": "^9.0.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.65.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.19.0"
}

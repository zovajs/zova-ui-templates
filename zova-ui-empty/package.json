{
  "name": "zova-ui-empty",
  "version": "5.1.92",
  "gitHead": "1c1c99cd879a2f00f32fb4b369a16ae90b9405da",
  "description": "A vue3 empty framework with ioc",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "init": "pnpm install --no-frozen-lockfile && zova :tools:deps",
    "dev": "npm run dev:ssr:admin",
    "build": "npm run build:ssr:admin",
    "preview": "npm run preview:ssr:admin",
    "dev:spa": "npm run prerun && quasar dev --mode spa --flavor admin",
    "build:spa": "npm run prerun && quasar build --mode spa --flavor admin",
    "preview:spa": "vite preview --outDir=dist/spa-admin",
    "prerun": "zova :tools:deps && npm run tsc",
    "tsc": "tsc --noEmit --project tsconfig.vue-tsc.json",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev:ssr:admin": "npm run prerun && quasar dev --mode ssr --flavor admin",
    "build:ssr:admin": "npm run prerun && quasar build --mode ssr --flavor admin",
    "preview:ssr:admin": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-admin/index.js\"",
    "dev:ssr:web": "npm run prerun && quasar dev --mode ssr --flavor web",
    "build:ssr:web": "npm run prerun && quasar build --mode ssr --flavor web",
    "preview:ssr:web": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-web/index.js\""
  },
  "dependencies": {
    "@cabloy/compose": "^2.1.5",
    "@cabloy/deps": "^1.1.5",
    "@cabloy/json5": "^1.1.6",
    "@cabloy/logger": "^1.1.10",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/utils": "^2.1.18",
    "@cabloy/vue-router": "^4.4.16",
    "@cabloy/word-utils": "^2.1.9",
    "@cabloy/zod-openapi": "^1.1.6",
    "@tanstack/query-core": "^5.100.10",
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/vue-form": "^1.32.0",
    "@tanstack/vue-query": "^5.100.10",
    "@tanstack/vue-table": "^8.21.3",
    "axios": "^1.16.1",
    "compression": "^1.8.1",
    "connect": "^3.7.0",
    "cors": "^2.8.6",
    "csx": "^10.0.2",
    "defu": "^6.1.7",
    "express": "^5.2.1",
    "luxon": "^3.7.2",
    "mutate-on-copy": "^1.1.8",
    "openapi3-ts": "^4.5.0",
    "quasar": "^2.19.3",
    "table-identity": "^1.1.4",
    "typestyle": "^2.4.0",
    "vue": "^3.5.34",
    "vue-router": "npm:@cabloy/vue-router@^4.4.16",
    "zod": "^4.4.3",
    "zova": "^5.1.71",
    "zova-jsx": "^1.1.41",
    "zova-module-a-api": "^5.1.10",
    "zova-module-a-app": "^5.1.12",
    "zova-module-a-bean": "^5.1.18",
    "zova-module-a-behavior": "^5.1.13",
    "zova-module-a-behaviors": "^5.1.10",
    "zova-module-a-boundary": "^5.1.10",
    "zova-module-a-command": "^5.1.21",
    "zova-module-a-fetch": "^5.1.12",
    "zova-module-a-form": "^5.1.26",
    "zova-module-a-icon": "^5.1.14",
    "zova-module-a-interceptor": "^5.1.17",
    "zova-module-a-logger": "^5.1.11",
    "zova-module-a-meta": "^5.1.10",
    "zova-module-a-model": "^5.1.18",
    "zova-module-a-openapi": "^5.1.23",
    "zova-module-a-router": "^5.1.15",

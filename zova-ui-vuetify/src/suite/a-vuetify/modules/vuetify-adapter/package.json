{
  "name": "zova-module-vuetify-adapter",
  "version": "5.0.0",
  "description": "vuetify",
  "keywords": [
    "Zova Module"
  ],
  "author": "zhennann",
  "files": [
    "dist",
    "src",
    "icons",
    "assets"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@date-io/core": "^3.2.0",
    "@date-io/luxon": "^3.2.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "vuetify-adapter",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-zova": "5.0.0"
    },
    "globalDependencies": {
      "@date-io/luxon": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "vuetify/lib"
          ],
          "output": "vuetify"
        },
        {
          "match": [
            "@date-io/core",
            "@date-io/luxon"
          ],
          "output": "date-io-luxon"
        }
      ]
    }
  }
}
